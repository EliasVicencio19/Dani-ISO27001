{
  "version": 2,
  "builds": [
    {
      "src": "dani-project-front/**",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dani-project-front/build"
      }
    },
    {
      "src": "dani-project-back/app/api/index.py",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.12"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "dani-project-back/app/api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "dani-project-front/build/$1"
    }
  ]
}
{
  "version": 2,
  "buildCommand": "cd Producto/dani-project-front && npm install && CI=false npm run build",
  "outputDirectory": "Producto/dani-project-front/build",
  "installCommand": "cd Producto/dani-project-front && npm install",
  "framework": "create-react-app",
  "env": {
    "VITE_API_URL": "https://dani-iso27001-backend.onrender.com",
    "REACT_APP_API_URL": "https://dani-iso27001-backend.onrender.com",
    "DATABASE_URL": "postgresql+asyncpg://neondb_owner:npg_mpdzXq6TFQ3j@ep-green-block-amzbcsvu.c-5.us-east-1.aws.neon.tech/neondb?ssl=require"
  },
  "builds": [
    {
      "src": "Producto/dani-project-front/build/**",
      "use": "@vercel/static"
    },
    {
      "src": "Producto/dani-project-back/app/api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "Producto/dani-project-back/app/api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "Producto/dani-project-front/build/index.html"
    }
  ]
}
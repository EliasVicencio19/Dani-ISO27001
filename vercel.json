{
  "buildCommand": "cd Producto/frontend && npm install && npm run build",
  "outputDirectory": "Producto/frontend/build",
  "installCommand": "cd Producto/frontend && npm install",
  "framework": "create-react-app",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/Producto/frontend/build/index.html"
    }
  ]
}
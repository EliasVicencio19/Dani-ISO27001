{
  "buildCommand": "cd Producto/dani-project-front && npm install && npm run build",
  "outputDirectory": "Producto/dani-project-front/build",
  "installCommand": "cd Producto/dani-project-front && npm install",
  "framework": "create-react-app",
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/Producto/dani-project-front/build/static/$1"
    },
    {
      "src": "/manifest.json",
      "dest": "/Producto/dani-project-front/build/manifest.json"
    },
    {
      "src": "/favicon.ico",
      "dest": "/Producto/dani-project-front/build/favicon.ico"
    },
    {
      "src": "/asset-manifest.json",
      "dest": "/Producto/dani-project-front/build/asset-manifest.json"
    },
    {
      "src": "/(.*)",
      "dest": "/Producto/dani-project-front/build/index.html"
    },
    {
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
  ]
}